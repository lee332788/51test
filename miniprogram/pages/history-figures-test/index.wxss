.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.header-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.preference-section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 30rpx;
  font-weight: bold;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s ease;
  position: relative;
}

.option-item.selected {
  background: rgba(255, 215, 0, 0.15);
  border-color: rgba(255, 215, 0, 0.5);
}

.option-icon {
  font-size: 60rpx;
  flex-shrink: 0;
}

.option-content {
  flex: 1;
}

.option-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: bold;
}

.start-section {
  margin-bottom: 40rpx;
}

.btn-start {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  color: #1a1a2e;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 10rpx 40rpx rgba(255, 215, 0, 0.3);
}

.btn-start.disabled {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.4);
  box-shadow: none;
}

.info-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}