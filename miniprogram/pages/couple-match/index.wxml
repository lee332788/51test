<view class="container">
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <view class="progress-text">第 {{currentIndex + 1}} 题 / 共 {{questions.length}} 题</view>

  <view class="question-card" wx:if="{{!showResult}}">
    <view class="question-text">{{currentQuestion.text}}</view>
    <view class="options">
      <view class="option {{selectedOption === 'A' ? 'selected' : ''}}" bindtap="selectOption" data-option="A" data-value="4">
        <view class="option-label">A</view>
        <view class="option-text">{{currentQuestion.optionA}}</view>
      </view>
      <view class="option {{selectedOption === 'B' ? 'selected' : ''}}" bindtap="selectOption" data-option="B" data-value="3">
        <view class="option-label">B</view>
        <view class="option-text">{{currentQuestion.optionB}}</view>
      </view>
      <view class="option {{selectedOption === 'C' ? 'selected' : ''}}" bindtap="selectOption" data-option="C" data-value="2">
        <view class="option-label">C</view>
        <view class="option-text">{{currentQuestion.optionC}}</view>
      </view>
      <view class="option {{selectedOption === 'D' ? 'selected' : ''}}" bindtap="selectOption" data-option="D" data-value="1">
        <view class="option-label">D</view>
        <view class="option-text">{{currentQuestion.optionD}}</view>
      </view>
    </view>
    <button class="btn-prev {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="prevQuestion" disabled="{{currentIndex === 0}}">
      ← 上一题
    </button>
  </view>

  <view class="result-card" wx:if="{{showResult}}">
    <view class="result-emoji">{{result.emoji}}</view>
    <view class="match-score">{{matchScore}}</view>
    <view class="match-label">匹配度</view>
    <view class="result-name">{{result.name}}</view>
    <view class="result-desc">{{result.description}}</view>
    <view class="result-tags">
      <view class="tag" wx:for="{{result.tags}}" wx:key="*this">{{item}}</view>
    </view>

    <view class="analysis-section">
      <view class="analysis-title">🔍 详细分析</view>
      <view class="dimension-list">
        <view class="dimension-item" wx:for="{{analysis}}" wx:key="name">
          <view class="dimension-name">{{item.name}}</view>
          <view class="dimension-bar">
            <view class="dimension-fill" style="width: {{item.percentage}}%"></view>
          </view>
          <view class="dimension-level {{item.level === '非常契合' ? 'excellent' : item.level === '较好' ? 'good' : 'normal'}}">{{item.level}}</view>
        </view>
      </view>
    </view>

    <button class="btn-restart" bindtap="restart">重新测试</button>
  </view>
</view>