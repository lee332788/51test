.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 50%, #43e97b 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 6rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #007adf 0%, #00ecbc 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  color: rgba(0, 0, 0, 0.5);
  font-size: 28rpx;
  margin-bottom: 60rpx;
}

.question-card {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

.question-text {
  font-size: 36rpx;
  color: #333;
  line-height: 56rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.option {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(0, 122, 223, 0.2);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s ease;
}

.option.selected {
  background: rgba(0, 122, 223, 0.1);
  border-color: #007adf;
}

.option-label {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #007adf 0%, #00ecbc 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  line-height: 44rpx;
  flex: 1;
}

.btn-prev {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.5);
  color: #007adf;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0, 122, 223, 0.3);
}

.btn-prev.disabled {
  opacity: 0.4;
}

.result-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

.city-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.city-name {
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #007adf 0%, #00ecbc 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
}

.result-name {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.result-desc {
  font-size: 30rpx;
  color: #666;
  line-height: 50rpx;
  margin-bottom: 40rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 60rpx;
}

.tag {
  background: rgba(0, 122, 223, 0.1);
  color: #007adf;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-restart {
  width: 100%;
  height: 100rpx;
  background: rgba(0, 122, 223, 0.1);
  color: #007adf;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0, 122, 223, 0.3);
}