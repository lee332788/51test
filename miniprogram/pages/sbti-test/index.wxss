.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560 0%, #ff6b6b 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-bottom: 60rpx;
}

.question-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  backdrop-filter: blur(10rpx);
}

.question-text {
  font-size: 36rpx;
  color: #fff;
  line-height: 56rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.option {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s ease;
}

.option.selected {
  background: rgba(233, 69, 96, 0.3);
  border-color: #e94560;
}

.option-label {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #fff;
  line-height: 44rpx;
  flex: 1;
}

.btn-prev {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.btn-prev.disabled {
  opacity: 0.4;
}

.result-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.result-type {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
}

.result-name {
  display: none;
}

.result-desc {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 50rpx;
  margin-bottom: 40rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 60rpx;
}

.tag {
  background: rgba(233, 69, 96, 0.3);
  color: #ff6b6b;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-restart {
  width: 100%;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}