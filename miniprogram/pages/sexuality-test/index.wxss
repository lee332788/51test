.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #fff 0%, #f093fb 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-bottom: 60rpx;
}

.question-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 50rpx 35rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.question-text {
  font-size: 34rpx;
  color: #764ba2;
  line-height: 52rpx;
  margin-bottom: 50rpx;
  text-align: center;
  font-weight: bold;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 50rpx;
}

.option {
  background: rgba(102, 126, 234, 0.08);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.3s ease;
}

.option.selected {
  background: rgba(102, 126, 234, 0.2);
  border-color: #667eea;
  transform: scale(1.02);
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.option-text {
  font-size: 28rpx;
  color: #764ba2;
  line-height: 42rpx;
  flex: 1;
}

.btn-prev {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #764ba2;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.btn-prev.disabled {
  opacity: 0.4;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 50rpx 35rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.result-emoji {
  font-size: 110rpx;
  margin-bottom: 20rpx;
}

.result-type {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.result-name {
  font-size: 30rpx;
  color: #764ba2;
  margin-bottom: 30rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 48rpx;
  margin-bottom: 30rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}

.tag {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.analysis-section {
  background: rgba(102, 126, 234, 0.08);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 30rpx;
}

.analysis-title {
  font-size: 28rpx;
  color: #764ba2;
  font-weight: bold;
  margin-bottom: 24rpx;
  text-align: left;
}

.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dimension-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.1);
}

.dimension-item:last-child {
  border-bottom: none;
}

.dimension-label {
  font-size: 26rpx;
  color: #666;
}

.dimension-value {
  font-size: 26rpx;
  font-weight: bold;
}

.spectrum-section {
  background: rgba(102, 126, 234, 0.08);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 30rpx;
}

.spectrum-title {
  font-size: 28rpx;
  color: #764ba2;
  font-weight: bold;
  margin-bottom: 24rpx;
  text-align: left;
}

.spectrum-bar {
  position: relative;
  height: 24rpx;
  background: linear-gradient(90deg, #4CAF50 0%, #FFEB3B 50%, #2196F3 100%);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.spectrum-marker {
  position: absolute;
  top: -40rpx;
  transform: translateX(-50%);
  background: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #764ba2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  white-space: nowrap;
}

.spectrum-labels {
  display: flex;
  justify-content: space-between;
}

.spectrum-label {
  font-size: 24rpx;
  color: #666;
}

.result-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 38rpx;
}

.btn-restart {
  width: 100%;
  height: 96rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #764ba2;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
}