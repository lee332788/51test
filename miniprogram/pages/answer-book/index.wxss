.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.eye-container {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 60rpx;
  position: relative;
}

.eye-outer {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, #2d2d44 0%, #1a1a2e 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(255, 215, 0, 0.3), inset 0 0 40rpx rgba(0, 0, 0, 0.5);
  position: relative;
  animation: eyeGlow 3s ease-in-out infinite;
}

.eye-outer::before,
.eye-outer::after {
  content: '';
  position: absolute;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 50%;
}

.eye-outer::before {
  width: 120%;
  height: 120%;
  animation: rotate1 20s linear infinite;
}

.eye-outer::after {
  width: 140%;
  height: 140%;
  animation: rotate2 25s linear infinite reverse;
}

.eye-inner {
  width: 60%;
  height: 60%;
  border-radius: 50%;
  background: radial-gradient(circle, #ffe4b5 0%, #daa520 50%, #8b4513 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.5);
}

.eye-pupil {
  width: 40%;
  height: 40%;
  border-radius: 50%;
  background: radial-gradient(circle, #2d2d2d 0%, #000 100%);
  position: relative;
}

.eye-pupil::after {
  content: '';
  position: absolute;
  width: 20%;
  height: 20%;
  background: #fff;
  border-radius: 50%;
  top: 20%;
  left: 30%;
}

@keyframes eyeGlow {
  0%, 100% {
    box-shadow: 0 0 60rpx rgba(255, 215, 0, 0.3), inset 0 0 40rpx rgba(0, 0, 0, 0.5);
  }
  50% {
    box-shadow: 0 0 100rpx rgba(255, 215, 0, 0.5), inset 0 0 40rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes rotate1 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes rotate2 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.title-small {
  font-size: 32rpx;
  color: #daa520;
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
}

.title-main {
  font-size: 80rpx;
  font-weight: bold;
  color: #daa520;
  letter-spacing: 20rpx;
  margin-bottom: 60rpx;
  text-shadow: 0 0 30rpx rgba(255, 215, 0, 0.5);
}

.description {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.description text {
  font-size: 32rpx;
  color: #ffe4b5;
  line-height: 50rpx;
  text-align: center;
}

.answer-container {
  width: 100%;
  padding: 60rpx 40rpx;
  background: rgba(255, 215, 0, 0.1);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 20rpx;
  margin-bottom: 60rpx;
  animation: fadeIn 0.8s ease-out;
}

.answer-text {
  font-size: 36rpx;
  color: #ffe4b5;
  line-height: 60rpx;
  text-align: center;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.btn-start {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #daa520 0%, #b8860b 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(218, 165, 32, 0.4);
  transition: all 0.3s ease;
}

.btn-start:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(218, 165, 32, 0.3);
}

.btn-start[disabled] {
  opacity: 0.6;
}