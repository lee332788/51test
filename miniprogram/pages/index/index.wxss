.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.answer-book-section {
  margin-bottom: 50rpx;
}

.answer-book-card {
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.15) 0%, rgba(255, 215, 0, 0.1) 100%);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.answer-book-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.1) 0%, transparent 70%);
  animation: shimmer 4s ease-in-out infinite;
}

@keyframes shimmer {
  0%, 100% { transform: translate(-25%, -25%); }
  50% { transform: translate(25%, 25%); }
}

.eye-container {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  position: relative;
}

.eye-outer {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, #2d2d44 0%, #1a1a2e 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.4);
  position: relative;
  animation: eyeGlow 3s ease-in-out infinite;
}

.eye-outer::before {
  content: '';
  position: absolute;
  width: 120%;
  height: 120%;
  border: 2rpx solid rgba(255, 215, 0, 0.2);
  border-radius: 50%;
  animation: rotate1 20s linear infinite;
}

.eye-inner {
  width: 60%;
  height: 60%;
  border-radius: 50%;
  background: radial-gradient(circle, #ffe4b5 0%, #daa520 50%, #8b4513 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-pupil {
  width: 40%;
  height: 40%;
  border-radius: 50%;
  background: radial-gradient(circle, #2d2d2d 0%, #000 100%);
  position: relative;
}

.eye-pupil::after {
  content: '';
  position: absolute;
  width: 20%;
  height: 20%;
  background: #fff;
  border-radius: 50%;
  top: 20%;
  left: 30%;
}

@keyframes eyeGlow {
  0%, 100% { box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.4); }
  50% { box-shadow: 0 0 60rpx rgba(255, 215, 0, 0.6); }
}

@keyframes rotate1 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.answer-book-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #daa520;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.answer-book-subtitle {
  font-size: 28rpx;
  color: rgba(255, 228, 181, 0.8);
  margin-bottom: 30rpx;
}

.answer-book-btn {
  display: inline-block;
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #daa520 0%, #b8860b 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(218, 165, 32, 0.4);
}

.tests-section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
  margin-right: 20rpx;
}

.tests-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.test-card {
  width: calc(50% - 12rpx);
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.test-card:active {
  transform: scale(0.98);
}

.test-card.mbti {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
  border-color: rgba(102, 126, 234, 0.3);
}

.test-card.sbti {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.2) 0%, rgba(255, 107, 107, 0.2) 100%);
  border-color: rgba(233, 69, 96, 0.3);
}

.test-card.couple {
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.2) 0%, rgba(196, 69, 105, 0.2) 100%);
  border-color: rgba(255, 107, 157, 0.3);
}

.test-card.city {
  background: linear-gradient(135deg, rgba(0, 122, 223, 0.2) 0%, rgba(0, 236, 188, 0.2) 100%);
  border-color: rgba(0, 122, 223, 0.3);
}

.test-card.love-brain {
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.2) 0%, rgba(196, 69, 105, 0.2) 100%);
  border-color: rgba(255, 107, 157, 0.3);
}

.test-card.sexuality {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(240, 147, 251, 0.2) 100%);
  border-color: rgba(102, 126, 234, 0.3);
}

.test-card.talent {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(59, 130, 246, 0.2) 100%);
  border-color: rgba(16, 185, 129, 0.3);
}

.test-card.history {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 152, 0, 0.2) 100%);
  border-color: rgba(255, 215, 0, 0.3);
}

.test-icon {
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.test-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.test-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.more-section {
  padding-bottom: 40rpx;
}

.more-list {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.more-item {
  display: flex;
  align-items: center;
  padding: 35rpx 30rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.05);
}

.more-item:last-child {
  border-bottom: none;
}

.more-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.more-text {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.more-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}